{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "acf/dexville-faq-accordion",
	"title": "FAQ Accordion",
	"category": "text",
	"icon": "editor-help",
	"description": "Accordion-style FAQ with FAQPage schema markup. No JavaScript required.",
	"keywords": ["faq", "accordion", "questions", "answers", "schema"],
	"textdomain": "dexville-fse",
	"acf": {
		"mode": "preview",
		"renderTemplate": "render.php"
	},
	"supports": {
		"align": ["wide", "full"],
		"anchor": true,
		"spacing": {
			"margin": true,
			"padding": true
		}
	},
	"style": "file:./style.css",
	"editorStyle": "file:./editor.css"
}
